// Fenix Cars driver registration schema
// Connection URLs live in prisma.config.ts (Prisma 7).

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum DriverStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayrollStatus {
  PENDING
  PAID
}

model Driver {
  id              String       @id @default(cuid())
  fullName        String
  employeeId      String       @unique
  contactNumber   String
  jobRole         String
  status          DriverStatus @default(PENDING)
  reviewedAt      DateTime?
  reviewedByEmail String?
  email           String?
  address         String?
  payrolls        Payroll[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([jobRole])
}

model Payroll {
  id          String        @id @default(cuid())
  driverId    String
  driver      Driver        @relation(fields: [driverId], references: [id], onDelete: Cascade)
  periodMonth Int
  periodYear  Int
  basicSalary Float
  allowances  Float         @default(0)
  deductions  Float         @default(0)
  netSalary   Float
  status      PayrollStatus @default(PENDING)
  paidDate    DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([driverId, periodMonth, periodYear])
  @@index([periodYear, periodMonth])
  @@index([status])
}
