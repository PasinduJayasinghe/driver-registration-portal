// Fenix Cars driver registration schema
// Connection URLs live in prisma.config.ts (Prisma 7).

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum DriverStatus {
  PENDING
  APPROVED
  REJECTED
}

model Driver {
  id              String       @id @default(cuid())
  fullName        String
  employeeId      String       @unique
  contactNumber   String
  jobRole         String
  status          DriverStatus @default(PENDING)
  reviewedAt      DateTime?
  reviewedByEmail String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status])
  @@index([createdAt])
}
